# ============================================
# .gitignore - Práctica Big Data 2026 Parte II
# ============================================

# --- Datasets y modelos pesados ---
# (los gestionaremos vía MinIO/Iceberg, NO vía git)
data/*.csv
data/*.csv.bz2
data/*.json
data/*.jsonl
!data/origin_dest_distances.jsonl
data/*.jsonl.bz2
!data/simple_flight_delay_features.jsonl.bz2
data/*.parquet
# models/ contiene modelos entrenados (~200KB). Los commiteamos para reproducibilidad.
# *.bin (los .bin de models/ se commitean para reproducibilidad)

# --- Logs y outputs ---
*.log
logs/
spark-warehouse/
metastore_db/
derby.log

# --- Caches y artefactos de build ---
# Scala / sbt
target/
project/target/
project/project/
.bsp/
.metals/
.bloop/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.venv/
venv/
env/
.python-version

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# --- Credenciales y secretos ---
*.pem
*.key
*-key.json
.env
.env.local
gcp-key.json
service-account.json

# --- Docker ---
.docker/

# --- Kubernetes ---
*.kubeconfig
secrets/

# --- Airflow ---
airflow.db
airflow-webserver.pid
airflow.cfg
unittests.cfg
webserver_config.py

# --- MLflow ---
mlruns/
mlartifacts/

# --- Sistema operativo ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Repositorio original como referencia local (no se commitea)
source_original/

# Backups temporales
*.bak

# Backups temporales
*.bak

# Build de Scala / sbt
src/flight_prediction/target/
src/flight_prediction/project/target/
src/flight_prediction/project/project/
# JAR de streaming: commiteado para reproducibilidad (es el job de prediccion)

# Build de Scala / sbt
src/flight_prediction/target/
src/flight_prediction/project/target/
src/flight_prediction/project/project/
# JAR de streaming: commiteado para reproducibilidad (es el job de prediccion)

# Airflow runtime (logs y plugins generados)
deployment/airflow/logs/
deployment/airflow/plugins/*
!deployment/airflow/plugins/.gitkeep

# Archivos copiados al build context de Spark para K8s (no commitear)
# simple_flight_delay_features.jsonl.bz2 empotrado para imagen K8s: commiteado
# models_to_embed/ empotrados en imagen K8s: commiteados para reproducibilidad

# Windows ADS metadata generado al copiar desde Downloads
*:Zone.Identifier

# Backups generados por edicion de manifests K8s
*.yaml.bak
*.Zone.Identifier
