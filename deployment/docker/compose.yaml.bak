# =============================================================
# Practica Big Data 2026 - Parte II
# Stack docker-compose
# =============================================================

name: bigdata-practica

networks:
  bigdata-net:
    driver: bridge
    name: bigdata-net

volumes:
  minio-data:
    name: bigdata-minio-data
  kafka-data:
    name: bigdata-kafka-data
  cassandra-data:
    name: bigdata-cassandra-data

services:

  # ===========================================================
  # MinIO - Object Storage S3-compatible (Lakehouse)
  # ===========================================================
  minio:
    image: minio/minio:RELEASE.2025-04-08T15-41-24Z
    container_name: bigdata-minio
    restart: unless-stopped
    networks:
      - bigdata-net
    ports:
      - "${MINIO_API_PORT:-9000}:9000"
      - "${MINIO_CONSOLE_PORT:-9001}:9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
      MINIO_REGION: ${MINIO_REGION:-us-east-1}
      MINIO_BROWSER_REDIRECT_URL: http://localhost:${MINIO_CONSOLE_PORT:-9001}
    volumes:
      - minio-data:/data
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  minio-init:
    image: minio/mc:RELEASE.2025-04-03T17-07-56Z
    container_name: bigdata-minio-init
    networks:
      - bigdata-net
    depends_on:
      minio:
        condition: service_healthy
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
      MINIO_APP_USER: ${MINIO_APP_USER}
      MINIO_APP_PASSWORD: ${MINIO_APP_PASSWORD}
      MINIO_LAKEHOUSE_BUCKET: ${MINIO_LAKEHOUSE_BUCKET}
    volumes:
      - ./bootstrap/minio-init.sh:/init.sh:ro
    entrypoint: ["/bin/sh", "/init.sh"]

  # ===========================================================
  # Kafka 4.2.0 (KRaft, single-node)
  # ===========================================================
  kafka:
    image: apache/kafka:4.2.0
    container_name: bigdata-kafka
    restart: unless-stopped
    networks:
      - bigdata-net
    ports:
      - "${KAFKA_EXTERNAL_PORT:-9094}:9094"
    environment:
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_NODE_ID: 1
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:9093
      KAFKA_LISTENERS: PLAINTEXT_INTERNAL://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093,PLAINTEXT_EXTERNAL://0.0.0.0:9094
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT_INTERNAL://kafka:9092,PLAINTEXT_EXTERNAL://localhost:9094
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT_INTERNAL:PLAINTEXT,PLAINTEXT_EXTERNAL:PLAINTEXT
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT_INTERNAL
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: 0
      KAFKA_AUTO_CREATE_TOPICS_ENABLE: "false"
      CLUSTER_ID: "MkU3OEVBNTcwNTJENDM2Qk"
      KAFKA_LOG_DIRS: /var/lib/kafka/data
    volumes:
      - kafka-data:/var/lib/kafka/data
    healthcheck:
      test: ["CMD-SHELL", "/opt/kafka/bin/kafka-topics.sh --bootstrap-server localhost:9092 --list || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 20s

  kafka-init:
    image: apache/kafka:4.2.0
    container_name: bigdata-kafka-init
    networks:
      - bigdata-net
    depends_on:
      kafka:
        condition: service_healthy
    volumes:
      - ./bootstrap/kafka-init.sh:/init.sh:ro
    entrypoint: ["/bin/sh", "/init.sh"]

  # ===========================================================
  # Cassandra 5.0 - BD analitica (distancias + predicciones)
  # ===========================================================
  cassandra:
    image: cassandra:5.0
    container_name: bigdata-cassandra
    restart: unless-stopped
    networks:
      - bigdata-net
    ports:
      # 9042 = puerto nativo CQL (clientes: cassandra-driver, Spark connector)
      - "${CASSANDRA_PORT:-9042}:9042"
    environment:
      # Nombre del cluster (cosmetico en single-node)
      CASSANDRA_CLUSTER_NAME: "BigDataCluster"
      # Snitch simple para single-node (no multi-DC)
      CASSANDRA_ENDPOINT_SNITCH: SimpleSnitch
      CASSANDRA_DC: datacenter1
      # Limitar memoria JVM de Cassandra (importante en WSL2 con RAM justa)
      # Por defecto Cassandra coge 1/4 de la RAM; lo fijamos para controlarlo
      MAX_HEAP_SIZE: "1G"
      HEAP_NEWSIZE: "256M"
    volumes:
      - cassandra-data:/var/lib/cassandra
    healthcheck:
      # 'cqlsh -e DESCRIBE KEYSPACES' devuelve 0 si Cassandra acepta CQL
      test: ["CMD-SHELL", "cqlsh -e 'DESCRIBE KEYSPACES' || exit 1"]
      interval: 15s
      timeout: 10s
      retries: 12
      start_period: 60s

  # ===========================================================
  # cassandra-init - Job: crea keyspace y tablas
  # ===========================================================
  cassandra-init:
    image: cassandra:5.0
    container_name: bigdata-cassandra-init
    networks:
      - bigdata-net
    depends_on:
      cassandra:
        condition: service_healthy
    volumes:
      - ./bootstrap/cassandra-init.cql:/init.cql:ro
    # cqlsh apunta al host 'cassandra' y ejecuta el fichero .cql
    entrypoint: ["/bin/sh", "-c", "cqlsh cassandra -f /init.cql && echo 'Cassandra schema OK'"]

