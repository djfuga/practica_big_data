# ========================================================
# Variables de entorno - Practica Big Data 2026
# Copia este fichero a .env y rellena los valores reales
# ========================================================

# --- MinIO ---
# Credenciales del usuario root (admin)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Credenciales de aplicacion (las que usaran Spark, Iceberg, scripts)
MINIO_APP_USER=bigdata
MINIO_APP_PASSWORD=bigdata-secret-2026

# Bucket principal del Lakehouse
MINIO_LAKEHOUSE_BUCKET=lakehouse

# Region (MinIO acepta cualquier valor, lo declaramos para compatibilidad S3)
MINIO_REGION=us-east-1

# --- Puertos expuestos al host WSL2 ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Kafka ---
# Puerto EXTERNAL expuesto al host (clientes desde WSL2)
# El listener INTERNAL (9092) NO se expone, solo es accesible desde dentro de docker
KAFKA_EXTERNAL_PORT=9094

# Bootstrap servers (referencia, no se sustituyen automaticamente)
# - Interno (Spark, Flask en docker): kafka:9092
# - Externo (scripts en WSL2):        localhost:9094

# --- Cassandra ---
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=flight_db

# --- Spark ---
SPARK_MASTER_UI_PORT=8080
SPARK_MASTER_PORT=7077
SPARK_WORKER_UI_PORT=8081

# --- Iceberg REST ---
ICEBERG_REST_PORT=8181

# --- Flask ---
WEB_PORT=5001
